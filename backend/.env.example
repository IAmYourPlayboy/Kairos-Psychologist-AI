# ===== Kairos — Основные настройки =====
APP_NAME=Kairos
DEBUG=true
SECRET_KEY=change-me-in-production

# ===== Сервер =====
HOST=0.0.0.0
PORT=8001

# ===== База данных (PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://kairos:kairos@localhost:5432/kairos

# ===== Redis (кэш, сессии, очереди) =====
REDIS_URL=redis://localhost:6379/0

# ===== LLM-провайдер =====
LLM_PROVIDER=yandex
LLM_BASE_URL=https://llm.api.cloud.yandex.net/foundationModels/v1
LLM_API_KEY=change-me
LLM_MODEL=yandexgpt-lite

# ===== CORS (через запятую) =====
CORS_ORIGINS=["http://localhost:3000"]

# ===== Логирование =====
LOG_LEVEL=info
