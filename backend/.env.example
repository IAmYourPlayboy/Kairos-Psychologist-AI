# ===== Kairos — Основные настройки =====
APP_NAME=Kairos
DEBUG=true
SECRET_KEY=change-me-in-production

# ===== Сервер =====
HOST=0.0.0.0
PORT=8001

# ===== База данных =====
# Для разработки (SQLite, файл рядом с проектом):
DATABASE_URL=sqlite+aiosqlite:///./kairos_dev.db
# Для продакшена (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://kairos:kairos@localhost:5432/kairos

# ===== Redis (кэш, сессии, очереди) — Блок 18+ =====
REDIS_URL=redis://localhost:6379/0

# ===== LLM-провайдер =====
# Yandex Cloud AI Studio (рекомендуется): получить ключ на console.cloud.yandex.ru
LLM_PROVIDER=yandex
LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1
LLM_API_KEY=change-me
# Модель: gpt://<folder_id>/qwen3-14b/latest
LLM_MODEL=gpt://your-folder-id/qwen3-14b/latest
# Yandex Cloud folder ID (нужен для модели)
YANDEX_FOLDER_ID=your-folder-id

# ===== CORS (через запятую) =====
CORS_ORIGINS=["http://localhost:3000"]

# ===== Логирование =====
LOG_LEVEL=info

# ===== Агенты =====
# Email для PubMed E-utilities API (обязательно по правилам NIH)
PUBMED_EMAIL=your-email@example.com
# Путь к базе знаний (эталонные статьи)
KNOWLEDGE_BASE_PATH=knowledge_base

# ===== Слой восприятия (Сессия 18+) =====
# Celery (broker + result backend). Используют другие БД того же Redis,
# чтобы не пересекаться с redis_url (db=0) для Mood.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Через сколько секунд после последнего сообщения запускать ReflectionAgent.
# 900 секунд = 15 минут.
REFLECTION_DELAY_SECONDS=900
